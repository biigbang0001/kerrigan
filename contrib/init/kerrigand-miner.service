# Kerrigan personal mining wallet daemon
# Receives mining payouts
# Generated by contrib/setup_fund_wallets.sh
#
# To modify options, use:
# $ systemctl edit kerrigand-miner.service

[Unit]
Description=Kerrigan daemon (miner wallet)
After=network-online.target
Wants=network-online.target

[Service]
ExecStart=/usr/bin/kerrigand \
            -pid=/run/kerrigand-miner/kerrigand.pid \
            -conf=/mnt/daemons/kerrigan-miner/kerrigan.conf \
            -datadir=/mnt/daemons/kerrigan-miner \
            -startupnotify='systemd-notify --ready' \
            -shutdownnotify='systemd-notify --stopping'

# Process management
Type=notify
NotifyAccess=main
PIDFile=/run/kerrigand-miner/kerrigand.pid

Restart=on-failure
TimeoutStartSec=infinity
TimeoutStopSec=600

# Run as kerrigan:kerrigan
User=kerrigan
Group=kerrigan

# /run/kerrigand-miner
RuntimeDirectory=kerrigand-miner
RuntimeDirectoryMode=0710

# Hardening measures
PrivateTmp=true
NoNewPrivileges=true
PrivateDevices=true

# Additional hardening
# Note: ProtectHome=true not used -- binary lives outside /home when installed via package
ProtectSystem=full
MemoryDenyWriteExecute=true
SystemCallArchitectures=native

[Install]
WantedBy=multi-user.target
